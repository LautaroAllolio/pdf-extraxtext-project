# ============================================================
# PaperSoul — Variables de entorno
# Copiá este archivo a .env y completá los valores
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Aplicación
# ------------------------------------------------------------
PROJECT_NAME="PaperSoul"
VERSION="1.0.0"
DESCRIPTION="API de extracción de texto desde PDFs con FastAPI y MongoDB"
API_V1_STR="/api/v1"

# ------------------------------------------------------------
# MongoDB
# Ejecución local:
#   MONGODB_URL="mongodb://localhost:27017/fastapi_db"
# Ejecución con Docker Compose:
#   MONGODB_URL="mongodb://admin:password@mongodb:27017/?authSource=admin"
# MongoDB Atlas:
#   MONGODB_URL="mongodb+srv://user:password@cluster.mongodb.net/fastapi_db"
# ------------------------------------------------------------
MONGODB_URL="mongodb://localhost:27017/fastapi_db"
MONGODB_DATABASE="fastapi_db"

# Credenciales root para Docker Compose
ROOT_USERNAME=admin
ROOT_PASSWORD=cambia_esta_password_en_produccion

# ------------------------------------------------------------
# Seguridad
# Generá una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
SECRET_KEY="cambia-esta-clave-secreta-en-produccion"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM="HS256"

# ------------------------------------------------------------
# Logging
# Opciones: DEBUG | INFO | WARNING | ERROR | CRITICAL
# ------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Validación de PDFs
# ------------------------------------------------------------
# Tamaño máximo permitido en MB
MAX_FILE_SIZE_BYTES=50

# ------------------------------------------------------------
# Extracción de texto
# ------------------------------------------------------------
# Mínimo de caracteres para considerar extracción exitosa con PyMuPDF
# Si el texto extraído es menor, se activa el fallback con OCR
MIN_TEXT_LENGTH=10

# DPI para conversión de páginas a imágenes en el proceso OCR
MIN_DPI=300